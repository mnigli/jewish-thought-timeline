---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import GlassCard from '../../components/ui/GlassCard.astro';
import SourceBadge from '../../components/ui/SourceBadge.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const sources = await getCollection('sources');
    return sources.map(source => ({
        params: { slug: source.id },
        props: { source },
    }));
}

const { source } = Astro.props;
const { Content } = await render(source);

const allSources = (await getCollection('sources')).sort((a, b) => a.data.dateStart - b.data.dateStart);
const currentIndex = allSources.findIndex(s => s.id === source.id);
const prevSource = currentIndex > 0 ? allSources[currentIndex - 1] : null;
const nextSource = currentIndex < allSources.length - 1 ? allSources[currentIndex + 1] : null;

const eraLabels: Record<string, string> = {
    'medieval': 'ימי הביניים',
    'early-modern': 'ראשית העת החדשה',
    'enlightenment': 'עידן ההשכלה',
    'modern': 'העת החדשה',
};

const eraColors: Record<string, string> = {
    'medieval': 'var(--era-medieval)',
    'early-modern': 'var(--era-early-modern)',
    'enlightenment': 'var(--era-enlightenment)',
    'modern': 'var(--era-modern)',
};

const sourceTypeColors: Record<string, string> = {
    diary: 'var(--type-diary)',
    travel: 'var(--type-travel)',
    autobiography: 'var(--type-autobiography)',
    memoirs: 'var(--type-memoirs)',
    letters: 'var(--type-letters)',
};

const questions = await getCollection('questions');
const relevantQuestions = questions.filter(q =>
    source.data.relevantQuestions.includes(q.data.id)
);
---

<BaseLayout title={source.data.nameHe} description={`${source.data.nameHe} — ${source.data.workTitleHe} (${source.data.dateDisplay})`}>
    <!-- Source Hero -->
    <section class="source-hero" style={`--source-accent: ${sourceTypeColors[source.data.sourceType]}`}>
        <div class="container">
            <div class="source-hero__breadcrumb">
                <a href="/sources/">המקורות</a>
                <span>&laquo;</span>
                <span>{source.data.nameHe}</span>
            </div>

            <div class="source-hero__content">
                <div class="source-hero__badges">
                    <SourceBadge type={source.data.sourceType} />
                    <span class={`badge badge--${source.data.era}`}>{eraLabels[source.data.era]}</span>
                    {source.data.reliability === 'disputed' && (
                        <span class="badge badge--warning">אמינות שנויה במחלוקת</span>
                    )}
                </div>

                <h1 class="source-hero__name font-display">{source.data.nameHe}</h1>
                <p class="source-hero__name-en">{source.data.nameEn}</p>

                <h2 class="source-hero__work font-display">{source.data.workTitleHe}</h2>
                <p class="source-hero__work-en">{source.data.workTitleEn}</p>

                <div class="source-hero__meta">
                    <div class="meta-item">
                        <span class="meta-item__label">תאריך</span>
                        <span class="meta-item__value">{source.data.dateDisplay}</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-item__label">מקום</span>
                        <span class="meta-item__value">{source.data.originCity}</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-item__label">אזור</span>
                        <span class="meta-item__value">{source.data.regionHe}</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-item__label">שפת הכתיבה</span>
                        <span class="meta-item__value">{source.data.language}</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-item__label">מגדר</span>
                        <span class="meta-item__value">{source.data.authorGender === 'female' ? 'אישה' : 'גבר'}</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Content -->
    <section class="section">
        <div class="container source-layout">
            <div class="source-content">
                <div class="prose">
                    <Content />
                </div>
            </div>

            <aside class="source-sidebar">
                <!-- Relevant Questions -->
                {relevantQuestions.length > 0 && (
                    <GlassCard variant="default" hover={false}>
                        <h3 class="sidebar-title font-display">שאלות מחקר רלוונטיות</h3>
                        <ul class="sidebar-questions">
                            {relevantQuestions.map(q => (
                                <li>
                                    <a href={`/questions/${q.id}/${source.id}/`} class="sidebar-question-link">
                                        <span class="sidebar-question-num">{q.data.id}</span>
                                        {q.data.shortTitleHe}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </GlassCard>
                )}

                <!-- Quick Facts -->
                <GlassCard variant="default" hover={false}>
                    <h3 class="sidebar-title font-display">נתונים מהירים</h3>
                    <div class="sidebar-facts">
                        <div class="sidebar-fact">
                            <span class="sidebar-fact__label">סוג מקור</span>
                            <span class="sidebar-fact__value">{source.data.sourceTypeHe}</span>
                        </div>
                        <div class="sidebar-fact">
                            <span class="sidebar-fact__label">תקופה</span>
                            <span class="sidebar-fact__value">{eraLabels[source.data.era]}</span>
                        </div>
                        <div class="sidebar-fact">
                            <span class="sidebar-fact__label">אמינות</span>
                            <span class="sidebar-fact__value">
                                {source.data.reliability === 'high' ? 'גבוהה' :
                                 source.data.reliability === 'moderate' ? 'בינונית' : 'שנויה במחלוקת'}
                            </span>
                        </div>
                    </div>
                </GlassCard>
            </aside>
        </div>
    </section>

    <!-- Navigation -->
    <section class="section source-nav-section">
        <div class="container">
            <div class="source-nav">
                {prevSource ? (
                    <a href={`/sources/${prevSource.id}/`} class="source-nav__link source-nav__link--prev">
                        <span class="source-nav__direction">&rarr; המקור הקודם</span>
                        <span class="source-nav__name font-display">{prevSource.data.nameHe}</span>
                        <span class="source-nav__date">{prevSource.data.dateDisplay}</span>
                    </a>
                ) : <div></div>}

                {nextSource ? (
                    <a href={`/sources/${nextSource.id}/`} class="source-nav__link source-nav__link--next">
                        <span class="source-nav__direction">המקור הבא &larr;</span>
                        <span class="source-nav__name font-display">{nextSource.data.nameHe}</span>
                        <span class="source-nav__date">{nextSource.data.dateDisplay}</span>
                    </a>
                ) : <div></div>}
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .source-hero {
        padding: calc(var(--nav-height) + var(--space-2xl)) 0 var(--space-3xl);
        position: relative;
        z-index: 1;
        background: var(--gradient-hero);
        border-bottom: 2px solid var(--source-accent);
    }

    .source-hero__breadcrumb {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        font-size: var(--text-sm);
        color: var(--text-muted);
        margin-bottom: var(--space-xl);
    }

    .source-hero__breadcrumb a {
        color: var(--text-muted);
    }

    .source-hero__breadcrumb a:hover {
        color: var(--accent-gold);
    }

    .source-hero__badges {
        display: flex;
        gap: var(--space-sm);
        margin-bottom: var(--space-lg);
        flex-wrap: wrap;
    }

    .badge--warning {
        background: rgba(245, 158, 11, 0.15);
        color: var(--accent-amber);
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .source-hero__name {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 900;
        margin-bottom: var(--space-xs);
        line-height: 1.2;
    }

    .source-hero__name-en {
        font-size: var(--text-lg);
        color: var(--text-muted);
        margin-bottom: var(--space-xl);
        direction: ltr;
        text-align: right;
    }

    .source-hero__work {
        font-size: var(--text-2xl);
        color: var(--accent-gold);
        margin-bottom: var(--space-xs);
    }

    .source-hero__work-en {
        font-size: var(--text-base);
        color: var(--text-dim);
        margin-bottom: var(--space-xl);
        direction: ltr;
        text-align: right;
    }

    .source-hero__meta {
        display: flex;
        gap: var(--space-2xl);
        flex-wrap: wrap;
        padding-top: var(--space-lg);
        border-top: 1px solid var(--border-glass);
    }

    .meta-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
    }

    .meta-item__label {
        font-size: var(--text-xs);
        color: var(--text-dim);
        font-weight: 600;
    }

    .meta-item__value {
        font-size: var(--text-base);
        color: var(--text-primary);
    }

    /* Layout */
    .source-layout {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: var(--space-3xl);
        align-items: start;
    }

    .source-content {
        min-width: 0;
    }

    /* Prose styling */
    .prose {
        font-size: var(--text-base);
        line-height: 2;
        color: var(--text-secondary);
    }

    .prose :global(h2) {
        font-family: var(--font-display);
        font-size: var(--text-2xl);
        color: var(--text-primary);
        margin: var(--space-3xl) 0 var(--space-lg);
        font-weight: 700;
    }

    .prose :global(h3) {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        color: var(--text-primary);
        margin: var(--space-2xl) 0 var(--space-md);
        font-weight: 600;
    }

    .prose :global(p) {
        margin-bottom: var(--space-lg);
    }

    .prose :global(blockquote) {
        border-right: 3px solid var(--accent-gold);
        padding-right: var(--space-lg);
        margin: var(--space-xl) 0;
        color: var(--text-muted);
        font-family: var(--font-display);
        font-size: var(--text-lg);
        line-height: 2;
        font-style: italic;
    }

    .prose :global(ul), .prose :global(ol) {
        padding-right: var(--space-xl);
        margin-bottom: var(--space-lg);
    }

    .prose :global(li) {
        margin-bottom: var(--space-sm);
    }

    .prose :global(strong) {
        color: var(--text-primary);
        font-weight: 600;
    }

    /* Sidebar */
    .source-sidebar {
        display: flex;
        flex-direction: column;
        gap: var(--space-lg);
        position: sticky;
        top: calc(var(--nav-height) + var(--space-lg));
    }

    .sidebar-title {
        font-size: var(--text-lg);
        color: var(--text-primary);
        margin-bottom: var(--space-md);
        font-weight: 700;
    }

    .sidebar-questions {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
    }

    .sidebar-question-link {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        color: var(--text-secondary);
        font-size: var(--text-sm);
        padding: var(--space-sm);
        border-radius: var(--radius-sm);
        transition: all var(--transition-fast);
    }

    .sidebar-question-link:hover {
        background: var(--bg-glass);
        color: var(--accent-gold);
    }

    .sidebar-question-num {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--accent-gold-dim);
        color: var(--accent-gold);
        font-size: var(--text-xs);
        font-weight: 700;
        flex-shrink: 0;
    }

    .sidebar-facts {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
    }

    .sidebar-fact {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .sidebar-fact__label {
        font-size: var(--text-sm);
        color: var(--text-dim);
    }

    .sidebar-fact__value {
        font-size: var(--text-sm);
        color: var(--text-primary);
        font-weight: 500;
    }

    /* Source Nav */
    .source-nav-section {
        border-top: 1px solid var(--border-glass);
    }

    .source-nav {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-xl);
    }

    .source-nav__link {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
        padding: var(--space-lg);
        border: 1px solid var(--border-glass);
        border-radius: var(--radius-md);
        text-decoration: none;
        transition: all var(--transition-base);
    }

    .source-nav__link:hover {
        border-color: var(--accent-gold);
        background: var(--bg-glass);
    }

    .source-nav__link--next {
        text-align: left;
        direction: ltr;
    }

    .source-nav__link--next {
        text-align: start;
    }

    .source-nav__direction {
        font-size: var(--text-xs);
        color: var(--accent-gold);
        font-weight: 600;
    }

    .source-nav__name {
        font-size: var(--text-xl);
        color: var(--text-primary);
        font-weight: 700;
    }

    .source-nav__date {
        font-size: var(--text-sm);
        color: var(--text-muted);
    }

    @media (max-width: 1024px) {
        .source-layout {
            grid-template-columns: 1fr;
        }

        .source-sidebar {
            position: static;
        }
    }

    @media (max-width: 768px) {
        .source-nav {
            grid-template-columns: 1fr;
        }

        .source-hero__meta {
            gap: var(--space-lg);
        }
    }
</style>
