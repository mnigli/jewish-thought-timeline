---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import SourceBadge from '../../components/ui/SourceBadge.astro';
import { getCollection } from 'astro:content';

const sources = (await getCollection('sources')).sort((a, b) => a.data.dateStart - b.data.dateStart);

const sourceTypeColors: Record<string, string> = {
    diary: 'var(--type-diary)',
    travel: 'var(--type-travel)',
    autobiography: 'var(--type-autobiography)',
    memoirs: 'var(--type-memoirs)',
    letters: 'var(--type-letters)',
};

const eraLabels: Record<string, string> = {
    'medieval': 'ימי הביניים',
    'early-modern': 'ראשית העת החדשה',
    'enlightenment': 'עידן ההשכלה',
    'modern': 'העת החדשה',
};

// Group by era
const eras = ['medieval', 'early-modern', 'enlightenment', 'modern'] as const;
const groupedSources = eras.map(era => ({
    era,
    label: eraLabels[era],
    sources: sources.filter(s => s.data.era === era),
}));
---

<BaseLayout title="המקורות" description="18 מקורות אישיים מן ההיסטוריה היהודית — יומנים, ספרי מסע, אוטוביוגרפיות, זיכרונות ואגרות">
    <section class="page-hero">
        <div class="container">
            <span class="page-hero__tag">18 טקסטים אישיים</span>
            <h1 class="page-hero__title font-display">המקורות</h1>
            <p class="page-hero__subtitle">
                שמונה עשר קולות יהודיים שנפרשים על פני 750 שנה — מספרי מסע של ימי הביניים
                ועד אוטוביוגרפיות של ראשית המאה העשרים. כל מקור הוא חלון לעולם שלם.
            </p>
        </div>
    </section>

    {groupedSources.map(group => (
        <section class="section" id={group.era}>
            <div class="container">
                <SectionHeader
                    title={group.label}
                    tag={`${group.sources.length} מקורות`}
                    align="start"
                />

                <div class="sources-grid">
                    {group.sources.map(source => (
                        <a
                            href={`/sources/${source.id}/`}
                            class="source-card reveal"
                            style={`--source-color: ${sourceTypeColors[source.data.sourceType]}`}
                        >
                            <div class="source-card__header">
                                <span class="source-card__date font-display">{source.data.dateDisplay}</span>
                                <SourceBadge type={source.data.sourceType} />
                            </div>
                            <h3 class="source-card__name font-display">{source.data.nameHe}</h3>
                            <p class="source-card__work">{source.data.workTitleHe}</p>
                            <p class="source-card__desc">{source.data.sourceTypeHe} &bull; {source.data.language}</p>
                            <p class="source-card__region">{source.data.regionHe}</p>
                            {source.data.reliability === 'disputed' && (
                                <span class="source-card__note">* אמינות שנויה במחלוקת</span>
                            )}
                        </a>
                    ))}
                </div>
            </div>
        </section>
    ))}
</BaseLayout>

<style>
    .page-hero {
        padding: calc(var(--nav-height) + var(--space-3xl)) 0 var(--space-3xl);
        position: relative;
        z-index: 1;
        background: var(--gradient-hero);
    }

    .page-hero__tag {
        display: inline-block;
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--accent-gold);
        letter-spacing: 0.15em;
        margin-bottom: var(--space-md);
        padding: var(--space-xs) var(--space-md);
        border: 1px solid rgba(245, 166, 35, 0.3);
        border-radius: var(--radius-full);
        background: rgba(245, 166, 35, 0.08);
    }

    .page-hero__title {
        font-size: var(--text-hero);
        font-weight: 900;
        margin-bottom: var(--space-lg);
    }

    .page-hero__subtitle {
        font-size: var(--text-lg);
        color: var(--text-secondary);
        line-height: 2;
        max-width: 700px;
    }

    .sources-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: var(--space-lg);
    }

    .source-card {
        display: block;
        background: var(--gradient-card);
        backdrop-filter: blur(20px);
        border: 1px solid var(--border-glass);
        border-right: 3px solid var(--source-color);
        border-radius: var(--radius-md);
        padding: var(--space-xl);
        text-decoration: none;
        color: inherit;
        transition: all var(--transition-base);
    }

    .source-card:hover {
        border-color: var(--border-glass-hover);
        border-right-color: var(--source-color);
        transform: translateY(-4px);
        box-shadow: var(--shadow-card-hover);
    }

    .source-card__header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-lg);
    }

    .source-card__date {
        font-size: var(--text-sm);
        color: var(--text-muted);
        font-weight: 500;
    }

    .source-card__name {
        font-size: var(--text-2xl);
        color: var(--text-primary);
        margin-bottom: var(--space-sm);
        font-weight: 700;
    }

    .source-card__work {
        font-size: var(--text-base);
        color: var(--accent-gold);
        margin-bottom: var(--space-sm);
    }

    .source-card__desc {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        margin-bottom: var(--space-xs);
    }

    .source-card__region {
        font-size: var(--text-xs);
        color: var(--text-dim);
    }

    .source-card__note {
        display: inline-block;
        margin-top: var(--space-sm);
        font-size: var(--text-xs);
        color: var(--accent-amber);
        font-style: italic;
    }

    @media (max-width: 768px) {
        .sources-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
