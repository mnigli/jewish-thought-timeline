---
import BaseLayout from '../components/layout/BaseLayout.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import SourceBadge from '../components/ui/SourceBadge.astro';
import { getCollection } from 'astro:content';

const sources = (await getCollection('sources')).sort((a, b) => a.data.dateStart - b.data.dateStart);

const stats = [
    { number: '18', label: 'מקורות אישיים' },
    { number: '750+', label: 'שנות כתיבה' },
    { number: '18', label: 'שאלות מחקר' },
    { number: '5', label: 'סוגי טקסט' },
];

const eraRanges = [
    { id: 'medieval', label: 'ימי הביניים', start: 1160, end: 1530, color: 'var(--era-medieval)' },
    { id: 'early-modern', label: 'ראשית העת החדשה', start: 1530, end: 1700, color: 'var(--era-early-modern)' },
    { id: 'enlightenment', label: 'עידן ההשכלה', start: 1700, end: 1850, color: 'var(--era-enlightenment)' },
    { id: 'modern', label: 'העת החדשה', start: 1850, end: 1920, color: 'var(--era-modern)' },
];

const sourceTypeColors: Record<string, string> = {
    diary: 'var(--type-diary)',
    travel: 'var(--type-travel)',
    autobiography: 'var(--type-autobiography)',
    memoirs: 'var(--type-memoirs)',
    letters: 'var(--type-letters)',
};
---

<BaseLayout>
    <!-- HERO -->
    <section class="hero">
        <div class="container hero__inner">
            <div class="hero__content">
                <span class="hero__tag">מחקר דיגיטלי במחשבה יהודית</span>
                <h1 class="hero__title font-display">
                    <span class="gold-text">ציר זמן</span>
                    <br />
                    של מחשבה יהודית
                </h1>
                <p class="hero__subtitle">
                    מסע דרך 750 שנה של כתיבה אישית יהודית — מיומני מסע של ימי הביניים
                    ועד אוטוביוגרפיות של שחר המודרנה. שמונה עשר קולות, שמונה עשר עולמות,
                    סיפור אחד של מחשבה שמשתנה.
                </p>
                <div class="hero__actions">
                    <a href="/sources/" class="btn btn--gold">גלו את המקורות</a>
                    <a href="/timeline/" class="btn btn--outline">ציר הזמן</a>
                </div>
            </div>

            <!-- Stats -->
            <div class="hero__stats">
                {stats.map(stat => (
                    <div class="stat">
                        <span class="stat__number gold-text font-display">{stat.number}</span>
                        <span class="stat__label">{stat.label}</span>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- OVERARCHING QUESTIONS -->
    <section class="section">
        <div class="container">
            <SectionHeader
                tag="במרכז המחקר"
                title="שתי שאלות-על"
                subtitle="שתי שאלות מרכזיות שעוברות כחוט השני דרך כל 18 המקורות ומאירות את המבנה העמוק של ההיסטוריה היהודית"
            />

            <div class="overarching-grid reveal">
                <GlassCard variant="gold">
                    <div class="overarching-card">
                        <span class="overarching-card__number font-display">א</span>
                        <h3 class="overarching-card__title font-display">
                            מגלות אל מודרנה
                        </h3>
                        <p class="overarching-card__text">
                            איך משתנה האופן שבו יהודים ראו את עצמם — מן הגלותי-קהילתי
                            אל האישי-מודרני והלאומי? כיצד ה"אני" היהודי עובר ממרכז הכובד
                            של הקולקטיב אל עולם פנימי עצמאי?
                        </p>
                    </div>
                </GlassCard>

                <GlassCard variant="gold">
                    <div class="overarching-card">
                        <span class="overarching-card__number font-display">ב</span>
                        <h3 class="overarching-card__title font-display">
                            האיום הגדול
                        </h3>
                        <p class="overarching-card__text">
                            מה יהודים בכל תקופה חשבו שהוא האיום הגדול ביותר על חייהם —
                            ומה זה מגלה על המבנה העמוק של התקופה? מרדיפה דתית ועד
                            התבוללות, מעוני ועד אובדן משמעות.
                        </p>
                    </div>
                </GlassCard>
            </div>
        </div>
    </section>

    <!-- MINI TIMELINE -->
    <section class="section">
        <div class="container">
            <SectionHeader
                tag="ציר זמן"
                title="750 שנה על קו אחד"
                subtitle="18 מקורות אישיים שמשתרעים על פני שמונה מאות שנה של חוויה יהודית"
            />

            <div class="mini-timeline reveal">
                <!-- Era bands -->
                <div class="mini-timeline__eras">
                    {eraRanges.map(era => {
                        const totalSpan = 1920 - 1160;
                        const left = ((era.start - 1160) / totalSpan) * 100;
                        const width = ((era.end - era.start) / totalSpan) * 100;
                        return (
                            <div
                                class="mini-timeline__era"
                                style={`right: ${left}%; width: ${width}%; background: ${era.color}15; border-top: 2px solid ${era.color}40;`}
                            >
                                <span class="mini-timeline__era-label" style={`color: ${era.color}`}>{era.label}</span>
                            </div>
                        );
                    })}
                </div>

                <!-- Timeline line -->
                <div class="mini-timeline__line">
                    {sources.map(source => {
                        const totalSpan = 1920 - 1160;
                        const pos = ((source.data.dateStart - 1160) / totalSpan) * 100;
                        const color = sourceTypeColors[source.data.sourceType];
                        return (
                            <a
                                href={`/sources/${source.id}/`}
                                class="mini-timeline__dot"
                                style={`right: ${pos}%; --dot-color: ${color};`}
                                title={`${source.data.nameHe} — ${source.data.dateDisplay}`}
                            >
                                <span class="mini-timeline__tooltip">
                                    <strong>{source.data.nameHe}</strong>
                                    <br />
                                    <small>{source.data.workTitleHe} ({source.data.dateDisplay})</small>
                                </span>
                            </a>
                        );
                    })}
                </div>

                <!-- Year markers -->
                <div class="mini-timeline__years">
                    <span>1160</span>
                    <span>1300</span>
                    <span>1500</span>
                    <span>1700</span>
                    <span>1900</span>
                </div>
            </div>

            <div class="timeline-legend reveal">
                <span class="legend-item"><span class="legend-dot" style="background: var(--type-diary)"></span> יומן</span>
                <span class="legend-item"><span class="legend-dot" style="background: var(--type-travel)"></span> ספר מסע</span>
                <span class="legend-item"><span class="legend-dot" style="background: var(--type-autobiography)"></span> אוטוביוגרפיה</span>
                <span class="legend-item"><span class="legend-dot" style="background: var(--type-memoirs)"></span> זיכרונות</span>
                <span class="legend-item"><span class="legend-dot" style="background: var(--type-letters)"></span> אגרות</span>
            </div>
        </div>
    </section>

    <!-- VIDEO SHOWCASE -->
    <section class="section">
        <div class="container">
            <SectionHeader
                tag="מסע חזותי"
                title="750 שנה בדקה אחת"
                subtitle="צפו במסע דרך ציר הזמן — מבנימין מטודלה ועד מרי אנטין"
            />
            <div class="video-showcase reveal">
                <div class="video-wrapper">
                    <video
                        class="video-player"
                        controls
                        preload="metadata"
                        poster="/video/timeline-journey-poster.jpg"
                    >
                        <source src="/video/timeline-journey.mp4" type="video/mp4" />
                    </video>
                </div>
            </div>
        </div>
    </section>

    <!-- SOURCE CARDS PREVIEW -->
    <section class="section">
        <div class="container">
            <SectionHeader
                tag="המקורות"
                title="שמונה עשר קולות"
                subtitle="מבנימין מטודלה במאה ה-12 ועד מרי אנטין בתחילת המאה ה-20 — כל מקור הוא חלון לעולם שלם"
            />

            <div class="sources-grid">
                {sources.map((source, i) => (
                    <a href={`/sources/${source.id}/`} class={`source-preview reveal`} style={`animation-delay: ${i * 0.05}s; --source-color: ${sourceTypeColors[source.data.sourceType]}`}>
                        <div class="source-preview__header">
                            <span class="source-preview__date font-display">{source.data.dateDisplay}</span>
                            <SourceBadge type={source.data.sourceType} />
                        </div>
                        <h3 class="source-preview__name font-display">{source.data.nameHe}</h3>
                        <p class="source-preview__work">{source.data.workTitleHe}</p>
                        <p class="source-preview__region">{source.data.regionHe}</p>
                    </a>
                ))}
            </div>

            <div class="section-cta reveal">
                <a href="/sources/" class="btn btn--outline">כל המקורות &larr;</a>
            </div>
        </div>
    </section>

    <!-- ENTRY PATHS -->
    <section class="section">
        <div class="container">
            <SectionHeader
                tag="נקודות כניסה"
                title="איך לחקור?"
                subtitle="ארבע דרכים שונות להיכנס אל העולם של המחשבה היהודית המתפתחת"
            />

            <div class="paths-grid reveal">
                <GlassCard href="/timeline/">
                    <div class="path-card">
                        <span class="path-card__icon">&#x23F3;</span>
                        <h3 class="path-card__title font-display">לפי ציר זמן</h3>
                        <p class="path-card__desc">מסע כרונולוגי מימי הביניים ועד המודרנה — צפו בשינוי מתגלה לאט</p>
                    </div>
                </GlassCard>

                <GlassCard href="/questions/">
                    <div class="path-card">
                        <span class="path-card__icon">&#x2753;</span>
                        <h3 class="path-card__title font-display">לפי שאלה</h3>
                        <p class="path-card__desc">18 שאלות מחקר שחותכות את כל המקורות — מזהות ועד כסף, מפחד ועד בית</p>
                    </div>
                </GlassCard>

                <GlassCard href="/sources/">
                    <div class="path-card">
                        <span class="path-card__icon">&#x1F4DC;</span>
                        <h3 class="path-card__title font-display">לפי מקור</h3>
                        <p class="path-card__desc">צללו לעומק של כל טקסט — ביוגרפיה, הקשר, ניתוח ושאלות שהוא מעורר</p>
                    </div>
                </GlassCard>

                <GlassCard href="/matrix/">
                    <div class="path-card">
                        <span class="path-card__icon">&#x1F5FA;</span>
                        <h3 class="path-card__title font-display">מטריצת הצלבה</h3>
                        <p class="path-card__desc">מפה אינטלקטואלית שלמה — כל מקור מול כל שאלה, במבט אחד</p>
                    </div>
                </GlassCard>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* === HERO === */
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding-top: calc(var(--nav-height) + var(--space-3xl));
        padding-bottom: var(--space-3xl);
        position: relative;
        z-index: 1;
        background: var(--gradient-hero);
    }

    .hero__inner {
        display: flex;
        flex-direction: column;
        gap: var(--space-4xl);
    }

    .hero__content {
        max-width: 800px;
    }

    .hero__tag {
        display: inline-block;
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--accent-gold);
        letter-spacing: 0.15em;
        margin-bottom: var(--space-lg);
        padding: var(--space-xs) var(--space-md);
        border: 1px solid rgba(245, 166, 35, 0.3);
        border-radius: var(--radius-full);
        background: rgba(245, 166, 35, 0.08);
    }

    .hero__title {
        font-size: var(--text-hero);
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: var(--space-xl);
    }

    .hero__subtitle {
        font-size: var(--text-lg);
        color: var(--text-secondary);
        line-height: 2;
        max-width: 650px;
        margin-bottom: var(--space-2xl);
    }

    .hero__actions {
        display: flex;
        gap: var(--space-md);
        flex-wrap: wrap;
    }

    .hero__stats {
        display: flex;
        gap: var(--space-3xl);
        padding-top: var(--space-2xl);
        border-top: 1px solid var(--border-glass);
    }

    .stat {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
    }

    .stat__number {
        font-size: var(--text-3xl);
        font-weight: 900;
    }

    .stat__label {
        font-size: var(--text-sm);
        color: var(--text-muted);
    }

    /* === BUTTONS === */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-sm);
        padding: var(--space-md) var(--space-xl);
        border-radius: var(--radius-md);
        font-size: var(--text-base);
        font-weight: 600;
        font-family: var(--font-primary);
        text-decoration: none;
        transition: all var(--transition-base);
        cursor: pointer;
        border: none;
    }

    .btn--gold {
        background: var(--gradient-gold);
        color: #0a0e1a;
    }

    .btn--gold:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-gold-glow);
        color: #0a0e1a;
    }

    .btn--outline {
        background: transparent;
        color: var(--text-primary);
        border: 1px solid var(--border-glass-hover);
    }

    .btn--outline:hover {
        background: var(--bg-glass);
        border-color: var(--accent-gold);
        color: var(--accent-gold);
    }

    /* === OVERARCHING QUESTIONS === */
    .overarching-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-xl);
    }

    .overarching-card {
        position: relative;
    }

    .overarching-card__number {
        display: block;
        font-size: 4rem;
        font-weight: 900;
        background: var(--gradient-gold);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        opacity: 0.3;
        line-height: 1;
        margin-bottom: var(--space-sm);
    }

    .overarching-card__title {
        font-size: var(--text-2xl);
        color: var(--text-primary);
        margin-bottom: var(--space-md);
    }

    .overarching-card__text {
        font-size: var(--text-base);
        color: var(--text-secondary);
        line-height: 2;
    }

    /* === MINI TIMELINE === */
    .mini-timeline {
        position: relative;
        padding: var(--space-3xl) 0 var(--space-xl);
    }

    .mini-timeline__eras {
        position: relative;
        height: 40px;
        margin-bottom: var(--space-md);
    }

    .mini-timeline__era {
        position: absolute;
        top: 0;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    }

    .mini-timeline__era-label {
        font-size: var(--text-xs);
        font-weight: 500;
        white-space: nowrap;
    }

    .mini-timeline__line {
        position: relative;
        height: 60px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: var(--radius-sm);
    }

    .mini-timeline__line::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 2%;
        right: 2%;
        height: 2px;
        background: linear-gradient(to left, var(--era-medieval), var(--era-early-modern), var(--era-enlightenment), var(--era-modern));
        opacity: 0.4;
    }

    .mini-timeline__dot {
        position: absolute;
        top: 50%;
        transform: translate(50%, -50%);
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--dot-color);
        border: 2px solid var(--bg-primary);
        cursor: pointer;
        transition: all var(--transition-fast);
        z-index: 2;
    }

    .mini-timeline__dot:hover {
        transform: translate(50%, -50%) scale(1.5);
        box-shadow: 0 0 15px var(--dot-color);
        z-index: 3;
    }

    .mini-timeline__tooltip {
        position: absolute;
        bottom: calc(100% + 12px);
        right: 50%;
        transform: translateX(50%);
        background: var(--bg-secondary);
        border: 1px solid var(--border-glass-hover);
        border-radius: var(--radius-sm);
        padding: var(--space-sm) var(--space-md);
        white-space: nowrap;
        font-size: var(--text-xs);
        color: var(--text-primary);
        pointer-events: none;
        opacity: 0;
        transition: opacity var(--transition-fast);
        z-index: 10;
    }

    .mini-timeline__dot:hover .mini-timeline__tooltip {
        opacity: 1;
    }

    .mini-timeline__years {
        display: flex;
        justify-content: space-between;
        padding: var(--space-sm) 2%;
        font-size: var(--text-xs);
        color: var(--text-dim);
        font-family: var(--font-display);
    }

    .timeline-legend {
        display: flex;
        justify-content: center;
        gap: var(--space-xl);
        margin-top: var(--space-xl);
        flex-wrap: wrap;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: var(--space-xs);
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    /* === SOURCES GRID === */
    .sources-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: var(--space-lg);
    }

    .source-preview {
        display: block;
        background: var(--gradient-card);
        backdrop-filter: blur(20px);
        border: 1px solid var(--border-glass);
        border-right: 3px solid var(--source-color);
        border-radius: var(--radius-md);
        padding: var(--space-lg);
        text-decoration: none;
        color: inherit;
        transition: all var(--transition-base);
    }

    .source-preview:hover {
        border-color: var(--border-glass-hover);
        border-right-color: var(--source-color);
        transform: translateY(-4px);
        box-shadow: var(--shadow-card-hover);
    }

    .source-preview__header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-md);
    }

    .source-preview__date {
        font-size: var(--text-sm);
        color: var(--text-muted);
        font-weight: 500;
    }

    .source-preview__name {
        font-size: var(--text-xl);
        color: var(--text-primary);
        margin-bottom: var(--space-xs);
        font-weight: 700;
    }

    .source-preview__work {
        font-size: var(--text-sm);
        color: var(--accent-gold);
        margin-bottom: var(--space-sm);
    }

    .source-preview__region {
        font-size: var(--text-xs);
        color: var(--text-dim);
    }

    .section-cta {
        text-align: center;
        margin-top: var(--space-2xl);
    }

    /* === PATHS GRID === */
    .paths-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-lg);
    }

    .path-card {
        text-align: center;
    }

    .path-card__icon {
        font-size: 2.5rem;
        display: block;
        margin-bottom: var(--space-md);
    }

    .path-card__title {
        font-size: var(--text-xl);
        color: var(--text-primary);
        margin-bottom: var(--space-sm);
    }

    .path-card__desc {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.8;
    }

    /* === VIDEO SHOWCASE === */
    .video-showcase {
        max-width: 960px;
        margin: 0 auto;
    }

    .video-wrapper {
        position: relative;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--border-glass);
        box-shadow: var(--shadow-card);
        aspect-ratio: 16 / 9;
    }

    .video-wrapper:hover {
        border-color: var(--border-glass-hover);
        box-shadow: var(--shadow-card-hover);
    }

    .video-player {
        width: 100%;
        height: 100%;
        display: block;
        background: var(--bg-primary);
    }

    /* === RESPONSIVE === */
    @media (max-width: 1024px) {
        .paths-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .hero {
            min-height: auto;
            padding-top: calc(var(--nav-height) + var(--space-2xl));
        }

        .hero__stats {
            flex-wrap: wrap;
            gap: var(--space-xl);
        }

        .overarching-grid {
            grid-template-columns: 1fr;
        }

        .sources-grid {
            grid-template-columns: 1fr;
        }

        .mini-timeline__era-label {
            font-size: 0.65rem;
        }

        .paths-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
