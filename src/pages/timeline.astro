---
import BaseLayout from '../components/layout/BaseLayout.astro';
import SourceBadge from '../components/ui/SourceBadge.astro';
import { getCollection } from 'astro:content';

const sources = (await getCollection('sources')).sort((a, b) => a.data.dateStart - b.data.dateStart);

const eras = [
    { id: 'medieval', label: 'ימי הביניים', start: '~1160', end: '~1530', color: 'var(--era-medieval)', desc: 'ספרי מסע ויומנים ראשונים — מיפוי העולם היהודי' },
    { id: 'early-modern', label: 'ראשית העת החדשה', start: '~1530', end: '~1700', color: 'var(--era-early-modern)', desc: 'הולדת הכתיבה העצמית — אוטוביוגרפיה, משבר, קול אישי' },
    { id: 'enlightenment', label: 'עידן ההשכלה', start: '~1700', end: '~1850', color: 'var(--era-enlightenment)', desc: 'המעבר הגדול — בין מסורת למודרנה, בין קהילה ליחיד' },
    { id: 'modern', label: 'העת החדשה', start: '~1850', end: '1912', color: 'var(--era-modern)', desc: 'תודעה לאומית, הגירה, שינוי פוליטי — הולדת הסובייקט המודרני' },
];

const sourceTypeColors: Record<string, string> = {
    diary: 'var(--type-diary)',
    travel: 'var(--type-travel)',
    autobiography: 'var(--type-autobiography)',
    memoirs: 'var(--type-memoirs)',
    letters: 'var(--type-letters)',
};

const historicalEvents = [
    { year: 1187, label: 'כיבוש ירושלים בידי צלאח א-דין' },
    { year: 1290, label: 'גירוש יהודי אנגליה' },
    { year: 1391, label: 'פרעות בספרד' },
    { year: 1492, label: 'גירוש ספרד' },
    { year: 1516, label: 'הכיבוש העות׳מאני של ארץ ישראל' },
    { year: 1648, label: 'גזרות ת״ח-ת״ט (חמלניצקי)' },
    { year: 1666, label: 'תנועת שבתאי צבי' },
    { year: 1789, label: 'המהפכה הצרפתית' },
    { year: 1791, label: 'תחום המושב ברוסיה' },
    { year: 1881, label: 'פוגרומים ברוסיה — תחילת העלייה הראשונה' },
    { year: 1897, label: 'הקונגרס הציוני הראשון' },
];
---

<BaseLayout title="ציר זמן" description="ציר זמן אינטראקטיבי של 18 מקורות אישיים מן ההיסטוריה היהודית">
    <section class="page-hero">
        <div class="container">
            <span class="page-hero__tag">750 שנה</span>
            <h1 class="page-hero__title font-display">ציר זמן</h1>
            <p class="page-hero__subtitle">
                מסע כרונולוגי דרך 18 מקורות אישיים — מימי הביניים ועד שחר המאה העשרים.
                כל נקודה על ציר הזמן היא חלון לעולם שלם של חוויה יהודית.
            </p>
        </div>
    </section>

    <!-- Filters -->
    <section class="filters-section">
        <div class="container">
            <div class="filters" id="filters">
                <div class="filter-group">
                    <span class="filter-label">סוג מקור:</span>
                    <button class="filter-btn active" data-filter="all">הכל</button>
                    <button class="filter-btn" data-filter="travel" style="--btn-color: var(--type-travel)">ספר מסע</button>
                    <button class="filter-btn" data-filter="diary" style="--btn-color: var(--type-diary)">יומן</button>
                    <button class="filter-btn" data-filter="autobiography" style="--btn-color: var(--type-autobiography)">אוטוביוגרפיה</button>
                    <button class="filter-btn" data-filter="memoirs" style="--btn-color: var(--type-memoirs)">זיכרונות</button>
                    <button class="filter-btn" data-filter="letters" style="--btn-color: var(--type-letters)">אגרות</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline -->
    <section class="section timeline-section">
        <div class="container">
            <div class="timeline">
                {eras.map(era => {
                    const eraSources = sources.filter(s => s.data.era === era.id);
                    return (
                        <div class="timeline__era" id={era.id}>
                            <div class="timeline__era-header" style={`--era-color: ${era.color}`}>
                                <div class="timeline__era-label">
                                    <h2 class="font-display">{era.label}</h2>
                                    <span class="timeline__era-dates">{era.start} — {era.end}</span>
                                </div>
                                <p class="timeline__era-desc">{era.desc}</p>
                            </div>

                            {eraSources.map((source, i) => {
                                const isLeft = i % 2 === 0;
                                return (
                                    <div
                                        class="timeline__entry reveal"
                                        data-type={source.data.sourceType}
                                        data-era={source.data.era}
                                        style={`--entry-color: ${sourceTypeColors[source.data.sourceType]}`}
                                    >
                                        <div class="timeline__dot"></div>
                                        <a href={`/sources/${source.id}/`} class="timeline__card glass-card">
                                            <div class="timeline__card-header">
                                                <span class="timeline__year font-display">{source.data.dateDisplay}</span>
                                                <SourceBadge type={source.data.sourceType} />
                                            </div>
                                            <h3 class="timeline__name font-display">{source.data.nameHe}</h3>
                                            <p class="timeline__work">{source.data.workTitleHe}</p>
                                            <p class="timeline__region">{source.data.regionHe}</p>
                                            {source.data.authorGender === 'female' && (
                                                <span class="timeline__gender-badge">&#9792; קול נשי</span>
                                            )}
                                        </a>
                                    </div>
                                );
                            })}

                            {/* Historical events in this era */}
                            {historicalEvents
                                .filter(e => {
                                    const eraStart = era.id === 'medieval' ? 1100 : era.id === 'early-modern' ? 1530 : era.id === 'enlightenment' ? 1700 : 1850;
                                    const eraEnd = era.id === 'medieval' ? 1530 : era.id === 'early-modern' ? 1700 : era.id === 'enlightenment' ? 1850 : 1920;
                                    return e.year >= eraStart && e.year < eraEnd;
                                })
                                .map(event => (
                                    <div class="timeline__event">
                                        <div class="timeline__event-dot"></div>
                                        <div class="timeline__event-content">
                                            <span class="timeline__event-year font-display">{event.year}</span>
                                            <span class="timeline__event-label">{event.label}</span>
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    );
                })}
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .page-hero {
        padding: calc(var(--nav-height) + var(--space-3xl)) 0 var(--space-2xl);
        background: var(--gradient-hero);
        position: relative;
        z-index: 1;
    }

    .page-hero__tag {
        display: inline-block;
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--accent-gold);
        letter-spacing: 0.15em;
        margin-bottom: var(--space-md);
        padding: var(--space-xs) var(--space-md);
        border: 1px solid rgba(245, 166, 35, 0.3);
        border-radius: var(--radius-full);
        background: rgba(245, 166, 35, 0.08);
    }

    .page-hero__title { font-size: var(--text-hero); font-weight: 900; margin-bottom: var(--space-lg); }
    .page-hero__subtitle { font-size: var(--text-lg); color: var(--text-secondary); line-height: 2; max-width: 700px; }

    /* Filters */
    .filters-section {
        position: sticky;
        top: var(--nav-height);
        z-index: 50;
        padding: var(--space-md) 0;
        background: rgba(10, 14, 26, 0.9);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-glass);
    }

    .filter-group {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        flex-wrap: wrap;
    }

    .filter-label { font-size: var(--text-sm); color: var(--text-muted); margin-left: var(--space-sm); }

    .filter-btn {
        padding: var(--space-xs) var(--space-md);
        border-radius: var(--radius-full);
        border: 1px solid var(--border-glass);
        background: transparent;
        color: var(--text-secondary);
        font-size: var(--text-xs);
        font-family: var(--font-primary);
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .filter-btn:hover {
        border-color: var(--btn-color, var(--border-glass-hover));
        color: var(--btn-color, var(--text-primary));
    }

    .filter-btn.active {
        background: var(--btn-color, var(--accent-gold));
        color: var(--bg-primary);
        border-color: var(--btn-color, var(--accent-gold));
        font-weight: 600;
    }

    /* Timeline */
    .timeline {
        position: relative;
        padding-right: 40px;
    }

    .timeline::before {
        content: '';
        position: absolute;
        right: 18px;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(to bottom, var(--era-medieval), var(--era-early-modern), var(--era-enlightenment), var(--era-modern));
        opacity: 0.3;
        border-radius: 2px;
    }

    .timeline__era {
        margin-bottom: var(--space-3xl);
    }

    .timeline__era-header {
        position: relative;
        padding: var(--space-xl) 0;
        margin-bottom: var(--space-xl);
        border-bottom: 2px solid var(--era-color);
    }

    .timeline__era-label {
        display: flex;
        align-items: baseline;
        gap: var(--space-md);
        margin-bottom: var(--space-sm);
    }

    .timeline__era-label h2 { font-size: var(--text-2xl); color: var(--era-color); }
    .timeline__era-dates { font-size: var(--text-sm); color: var(--text-dim); }
    .timeline__era-desc { font-size: var(--text-base); color: var(--text-secondary); }

    .timeline__entry {
        position: relative;
        margin-bottom: var(--space-xl);
        padding-right: var(--space-xl);
        transition: opacity 0.3s ease;
    }

    .timeline__entry.hidden {
        opacity: 0.15;
        pointer-events: none;
    }

    .timeline__dot {
        position: absolute;
        right: calc(-40px + 10px);
        top: var(--space-lg);
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--entry-color);
        border: 3px solid var(--bg-primary);
        box-shadow: 0 0 0 2px var(--entry-color);
        z-index: 2;
    }

    .timeline__card {
        display: block;
        text-decoration: none;
        color: inherit;
        border-right: 3px solid var(--entry-color);
        max-width: 600px;
    }

    .timeline__card:hover {
        border-color: var(--border-glass-hover);
        border-right-color: var(--entry-color);
    }

    .timeline__card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--space-md);
    }

    .timeline__year { font-size: var(--text-lg); color: var(--text-muted); font-weight: 500; }
    .timeline__name { font-size: var(--text-2xl); color: var(--text-primary); font-weight: 700; margin-bottom: var(--space-xs); }
    .timeline__work { font-size: var(--text-base); color: var(--accent-gold); margin-bottom: var(--space-sm); }
    .timeline__region { font-size: var(--text-sm); color: var(--text-dim); }

    .timeline__gender-badge {
        display: inline-block;
        margin-top: var(--space-sm);
        font-size: var(--text-xs);
        color: var(--accent-rose);
        padding: 2px var(--space-sm);
        border: 1px solid rgba(244, 63, 94, 0.3);
        border-radius: var(--radius-full);
        background: rgba(244, 63, 94, 0.1);
    }

    /* Historical Events */
    .timeline__event {
        position: relative;
        margin-bottom: var(--space-md);
        padding-right: var(--space-xl);
        display: flex;
        align-items: center;
        gap: var(--space-md);
    }

    .timeline__event-dot {
        position: absolute;
        right: calc(-40px + 14px);
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--text-dim);
        border: 2px solid var(--bg-primary);
        z-index: 2;
    }

    .timeline__event-content {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        font-size: var(--text-sm);
        color: var(--text-dim);
        padding: var(--space-xs) var(--space-md);
        border: 1px dashed var(--border-glass);
        border-radius: var(--radius-sm);
    }

    .timeline__event-year { font-weight: 600; color: var(--text-muted); }

    @media (max-width: 768px) {
        .timeline { padding-right: 30px; }
        .timeline::before { right: 12px; }
        .timeline__dot { right: calc(-30px + 6px); width: 16px; height: 16px; }
        .timeline__event-dot { right: calc(-30px + 8px); }
    }
</style>

<script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const entries = document.querySelectorAll('.timeline__entry');

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const filter = btn.getAttribute('data-filter');

            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            entries.forEach(entry => {
                if (filter === 'all' || entry.getAttribute('data-type') === filter) {
                    entry.classList.remove('hidden');
                } else {
                    entry.classList.add('hidden');
                }
            });
        });
    });
</script>
